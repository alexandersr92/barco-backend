{
  "kind": "collectionType",
  "collectionName": "channels",
  "info": {
    "singularName": "channel",
    "pluralName": "channels",
    "displayName": "Canal de Atención",
    "description": "Canales de atención: Avanz Móvil, e-Banking, sucursales, ATM, etc."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "buttonLabel": {
      "type": "string"
    },
    "buttonUrl": {
      "type": "string"
    },
    "buttonIcon": {
      "type": "enumeration",
      "enum": ["none", "phone"],
      "default": "none"
    },
    "features": {
      "type": "component",
      "component": "shared.feature-item",
      "repeatable": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
