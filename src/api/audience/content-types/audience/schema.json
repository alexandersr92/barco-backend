{
  "kind": "collectionType",
  "collectionName": "audiences",
  "info": {
    "singularName": "audience",
    "pluralName": "audiences",
    "displayName": "Audiencia",
    "description": "Pestañas principales del sitio (Personas, Empresas, Sobre nosotros). Cada una define su propio menú y agrupa sus páginas."
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "mainNav": {
      "type": "component",
      "component": "layout.nav-item",
      "repeatable": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::page.page",
      "mappedBy": "audience"
    }
  }
}
