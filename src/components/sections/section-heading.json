{
  "collectionName": "components_sections_section_headings",
  "info": {
    "displayName": "Section Heading",
    "icon": "bold"
  },
  "options": {},
  "attributes": {
    "kicker": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "align": {
      "type": "enumeration",
      "enum": ["left", "center"],
      "default": "left"
    },
    "background": {
      "type": "enumeration",
      "enum": ["none", "secondary"],
      "default": "none",
      "description": "Fondo de la sección: sin fondo, o banda azul petróleo a todo el ancho con texto blanco"
    },
    "maxWidth": {
      "type": "integer",
      "description": "Ancho máximo del contenido en px (por defecto 1220)"
    }
  }
}
